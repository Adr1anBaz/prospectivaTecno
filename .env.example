# API Keys - Obtener en:
# GROQ_API_KEY: https://console.groq.com
# DEEPGRAM_API_KEY: https://developers.deepgram.com

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM Provider: groq (default) | openrouter
LLM_PROVIDER=groq
# Groq: meta-llama/llama-4-scout-17b-16e-instruct (recomendado), llama-3.1-8b-instant, llama-3.3-70b-versatile
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Wake Word Engine
# Options: vosk (default, offline) | porcupine (more precise, requires access key)
WAKE_WORD_ENGINE=vosk

# Porcupine (Picovoice) - only needed if WAKE_WORD_ENGINE=porcupine
# Get access key: https://console.picovoice.ai/
# For custom keyword "blu", train .ppn file at https://picovoice.ai/console/
PORCUPINE_ACCESS_KEY=your_access_key_here
PORCUPINE_KEYWORD_PATH=./models/porcupine/blu_es.ppn

# Vosk Model Path - Ruta al modelo offline de Vosk para wake word
# Descargar con: uv run python scripts/download_vosk_model.py
VOSK_MODEL_PATH=./models/vosk/vosk-model-small-es-0.42

# MCP Server URL - Servidor MCP externo de informacion universitaria (JSON-RPC over HTTP)
# Repo: https://github.com/Adr1anBaz/mcp-blu
# El MCP server corre en su propia terminal y expone tools en /mcp
MCP_URL=http://localhost:8000/mcp
MCP_BEARER_TOKEN=change-me-to-a-random-secret

# Route API URL - Servidor externo de calculo de ruta (Dijkstra)
# Repo: https://github.com/Adr1anBaz/mcp-blu (route_server.py)
# Recibe POST /api/routes/calculate {"start": "nodo_a", "end": "nodo_b"}
# Devuelve: {"movement_files": ["ruta_001.csv", ...], "path": [...], "estimated_time": 45.0}
ROUTE_API_URL=http://localhost:8001

# Robot Start Node - Nodo del grafo donde inicia el robot
# Este nodo se actualiza automaticamente despues de cada navegacion
ROBOT_START_NODE=base

# Google Cloud Speech-to-Text Service Account (para STT_PROVIDER=googlecloud)
# Crear service account en: https://console.cloud.google.com/iam-admin/serviceaccounts
# Rol: Cloud Speech-to-Text API User -> Add Key -> JSON -> guardar en ./credentials/gcp-speech.json
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-speech.json

# STT Provider - Motor de Speech-to-Text
# Options: groq (Whisper, default) | deepgram (Nova-3 streaming) | googlecloud (Speech-to-Text, recomendado) | parakeet (local ONNX, requiere modelo descargado)
STT_PROVIDER=groq

# Parakeet Local STT Model (para STT_PROVIDER=parakeet)
# Ruta al modelo ONNX descargado por Handy (NO modificar archivos de Handy)
# Si no se especifica, usa la ruta por defecto de Handy
# PARAKET_MODEL_DIR=/home/rimuru/.local/share/com.pais.handy/models/parakeet-tdt-0.6b-v3-int8

# Post-TTS cooldown (ms) - tiempo de espera después de que el asistente hable
# para evitar que el micrófono capture el eco de la bocina y entre en bucle
# Default: 3000 (3 segundos). Aumentar si sigues escuchando "gracias" solo.
POST_TTS_COOLDOWN_MS=3000

# TTS Provider - Motor de Text-to-Speech
# Options: edge (recomendado, rapido y gratuito) | deepgram (Aura-2, online) | local (mock)
TTS_PROVIDER=edge

# TTS Voice Model
# Edge voices: es-MX-JorgeNeural (masculino), es-MX-DaliaNeural (femenino)
# Deepgram voices: aura-2-celeste-es, aura-2-alejandra-es, aura-2-sofia-es, aura-2-marcos-es, aura-2-octavio-es
TTS_MODEL=es-MX-JorgeNeural
