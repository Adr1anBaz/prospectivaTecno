# API Keys - Obtener en:
# GROQ_API_KEY: https://console.groq.com
# DEEPGRAM_API_KEY: https://developers.deepgram.com

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Wake Word Engine
# Options: vosk (default, offline) | porcupine (more precise, requires access key)
WAKE_WORD_ENGINE=vosk

# Porcupine (Picovoice) - only needed if WAKE_WORD_ENGINE=porcupine
# Get access key: https://console.picovoice.ai/
# For custom keyword "blu", train .ppn file at https://picovoice.ai/console/
PORCUPINE_ACCESS_KEY=your_access_key_here
PORCUPINE_KEYWORD_PATH=./models/porcupine/blu_es.ppn

# Vosk Model Path - Ruta al modelo offline de Vosk para wake word
# Descargar con: uv run python scripts/download_vosk_model.py
VOSK_MODEL_PATH=./models/vosk/vosk-model-small-es-0.42

# PostgreSQL Database (requerido por server.py)
# Ejemplo local: postgresql://user:pass@localhost:5432/campus
DATABASE_URL=postgresql://user:password@localhost:5432/campus_db

# MCP Server URL - Servidor MCP de información universitaria (JSON-RPC over HTTP)
# Corre con: uv run python server.py
# Endpoint por defecto: http://localhost:8000/mcp
MCP_URL=http://localhost:8000/mcp
MCP_BEARER_TOKEN=your_token_here

# Route API URL - API independiente de cálculo de ruta
# Recibe POST /api/routes/calculate {"start": "node_a", "end": "node_b"}
# Devuelve: {"movement_files": ["ruta_001.csv", ...], "path": [...], "estimated_time": 45.0}
# Nota: el servidor de rutas aún no está en main (ver notas del equipo)
ROUTE_API_URL=http://localhost:8081

# Robot Start Node - Nodo del grafo donde inicia el robot
# Este nodo se actualiza automáticamente después de cada navegación
ROBOT_START_NODE=base

# Google Cloud Speech-to-Text Service Account (para STT_PROVIDER=googlecloud)
# Crear service account en: https://console.cloud.google.com/iam-admin/serviceaccounts
# Rol: Cloud Speech-to-Text API User → Add Key → JSON → guardar en ./credentials/gcp-speech.json
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-speech.json

# STT Provider - Motor de Speech-to-Text
# Options: groq (Whisper, default) | deepgram (Nova-3 streaming) | googlecloud (Speech-to-Text, recomendado)
STT_PROVIDER=groq

# TTS Provider - Motor de Text-to-Speech
# Options: deepgram (Aura-2, default, online) | local (offline, mock for now)
TTS_PROVIDER=deepgram

# TTS Voice Model - Voz de Deepgram Aura-2
# Spanish voices: aura-2-celeste-es (default), aura-2-alejandra-es, aura-2-sofia-es, aura-2-marcos-es, aura-2-octavio-es
TTS_MODEL=aura-2-celeste-es
